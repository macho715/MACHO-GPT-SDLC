{
  "name": "mcp-dev-hub",
  "version": "3.0.0",
  "description": "Standalone MCP server for multi-AI dev state sharing — no GitHub/Linear required. v3: Session Lifecycle + Retro + Leader Election",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env=\"\"",
    "db:init:local": "wrangler d1 execute mcp-dev-hub-db --local --file=src/db/schema.sql",
    "db:init:prod": "wrangler d1 execute mcp-dev-hub-db --remote --file=src/db/schema.sql",
    "db:create": "wrangler d1 create mcp-dev-hub-db",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:fix": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "validate": "npm run type-check && npm run lint && npm test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260612.1",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-istanbul": "^4.1.8",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  },
  "dependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.15"
  }
}
